{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Useful Markdown Editor",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/useful-markdown-editor"
      ]
    }
  ]
}